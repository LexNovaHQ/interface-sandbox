# Firebase public web config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Interface app config
VITE_INTERFACE_APP_MODE=sandbox
VITE_INTERFACE_DEMO_MODE=true
VITE_INTERFACE_RUNTIME_VERSION=wrapper-batch-1

# Server-only Gemini pool variables
# Do NOT expose these with a VITE_ prefix.
GEMINI_SEARCH_API_KEYS=
GEMINI_JSON_API_KEYS=
GEMINI_REASONING_API_KEYS=
GEMINI_SEARCH_MODEL_SEQUENCE=gemini-2.5-flash,gemini-2.5-flash-lite
GEMINI_JSON_MODEL_SEQUENCE=gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-2.5-flash
GEMINI_FINAL_MODEL_SEQUENCE=gemini-3.5-flash,gemini-2.5-flash,gemini-3.1-flash-lite

# Runtime flags
AI_RATE_LIMIT_MODE=conservative
SANDBOX_PUBLIC_MODE=true
CLIENT_CONFIDENTIAL_INPUTS_ALLOWED=false
DILIGENCE_SOURCE_MODE=known_paths_plus_search
ENABLE_SEARCH_DISCOVERY=true
ENABLE_GEMINI_URL_CONTEXT=true
