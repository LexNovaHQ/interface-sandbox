# Firebase public web config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Interface app config
VITE_INTERFACE_APP_MODE=sandbox
VITE_INTERFACE_DEMO_MODE=true
VITE_INTERFACE_RUNTIME_VERSION=wrapper-batch-1

# Server-only variables for future Pages Functions / backend use
# Do NOT expose these with VITE_ prefix.
AI_PRIMARY_PROVIDER=gemini
GEMINI_API_KEY=server_secret_only_do_not_commit
GEMINI_PRIMARY_MODEL=gemini-3.5-flash
GEMINI_FAST_MODEL=gemini-3.1-flash-lite
AI_FALLBACK_PROVIDER=groq
GROQ_API_KEY=server_secret_only_do_not_commit
GROQ_PRIMARY_MODEL=
GROQ_FALLBACK_MODEL=
AI_RATE_LIMIT_MODE=conservative
SANDBOX_PUBLIC_MODE=true
CLIENT_CONFIDENTIAL_INPUTS_ALLOWED=false
DILIGENCE_SOURCE_MODE=known_paths_plus_search
ENABLE_SEARCH_DISCOVERY=true
ENABLE_GEMINI_URL_CONTEXT=true
