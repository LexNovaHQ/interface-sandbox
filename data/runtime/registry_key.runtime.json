  "threat_id_schema": {
    "format": "{ARCHETYPE}_{SUBCAT}_{VARIANT}",
    "regex": "^(UNI|DOE|JDG|CMP|CRT|RDR|ORC|TRN|SHD|OPT|MOV)_(CNS|LIA|HAL|INF|PRV|BIO|DEC|HRM|FRD|TRD)_(\\d{3}|IN\\d|LB\\d)$",
    "archetype_codes": [
      "UNI",
      "DOE",
      "JDG",
      "CMP",
      "CRT",
      "RDR",
      "ORC",
      "TRN",
      "SHD",
      "OPT",
      "MOV"
    ],
    "subcat_codes": [
      "CNS",
      "LIA",
      "HAL",
      "INF",
      "PRV",
      "BIO",
      "DEC",
      "HRM",
      "FRD",
      "TRD"
    ],
    "variant_patterns": {
      "NNN": {
        "meaning": "Standard 3-digit, zero-padded counter, scoped to `{ARCHETYPE}_{SUBCAT}`. Append-only. Retired threats keep their number."
      },
      "INn": {
        "meaning": "India-specific threat (DPDP / IT Act / CERT-In / MeitY origin). Single digit."
      },
      "LBn": {
        "meaning": "Lane B / Workplace Shield threat (internal-AI-use exposure). Single digit."
      }
    },
    "closed_vocabulary_discipline": true,
    "fin_folded_to_lia": true
  },
  "vocabularies": {
    "archetypes": {
      "UNI": {
        "archetype": "Universal",
        "detection_logic": "No archetype gate — applies to every product regardless of behavior.",
        "examples": "—",
        "legacy": "UNIVERSAL"
      },
      "DOE": {
        "archetype": "The Doer",
        "detection_logic": "Product **takes autonomous actions in the world** on a user's behalf without per-action human approval.",
        "examples": "bookings, transactions, sends, tool/API calls",
        "legacy": "INT.01"
      },
      "JDG": {
        "archetype": "The Judge",
        "detection_logic": "Product **outputs a consequential decision or score about a human** that gates access to something.",
        "examples": "hiring, credit, healthcare, insurance, admissions",
        "legacy": "INT.02"
      },
      "CMP": {
        "archetype": "The Companion",
        "detection_logic": "Product **forms an ongoing emotional or relational bond** with the user as a primary function.",
        "examples": "chatbots, therapy bots, AI companions, minors-facing chat",
        "legacy": "INT.03"
      },
      "CRT": {
        "archetype": "The Creator",
        "detection_logic": "Product **generates new copyrightable or synthetic output** as its primary output.",
        "examples": "text, image, audio, video, code, voice clones",
        "legacy": "INT.04"
      },
      "RDR": {
        "archetype": "The Reader",
        "detection_logic": "Product **ingests third-party data it does not own** to function.",
        "examples": "web scraping, RAG, training-corpus assembly, document Q&A",
        "legacy": "INT.05"
      },
      "ORC": {
        "archetype": "The Orchestrator",
        "detection_logic": "Product **routes requests across multiple models or sub-processors** dynamically.",
        "examples": "multi-LLM routers, model gateways, agent frameworks",
        "legacy": "INT.06"
      },
      "TRN": {
        "archetype": "The Translator",
        "detection_logic": "Product **processes biometric or audio signals** as input.",
        "examples": "voice, speech-to-text, diarization, face/voiceprint",
        "legacy": "INT.07"
      },
      "SHD": {
        "archetype": "The Shield",
        "detection_logic": "Product **is deployed to defend or monitor a system** for security purposes.",
        "examples": "threat detection, SOC automation, incident response",
        "legacy": "INT.08"
      },
      "OPT": {
        "archetype": "The Optimizer",
        "detection_logic": "Product **runs high-stakes optimization where its output directly moves money or controls operations.**",
        "examples": "trading, dynamic pricing, critical-infrastructure tuning",
        "legacy": "INT.09"
      },
      "MOV": {
        "archetype": "The Mover",
        "detection_logic": "Product **governs a physical system that can act on or in the physical world.**",
        "examples": "robotics, autonomous vehicles, drones, spatial computing",
        "legacy": "INT.10"
      }
    },
    "surfaces": {
      "Consumer-Public": {
        "meaning": "Product is consumer-facing / publicly accessible."
      },
      "Enterprise-Private": {
        "meaning": "Product sold B2B / behind enterprise contracts."
      },
      "PII": {
        "meaning": "Handles personally identifiable information."
      },
      "Employment": {
        "meaning": "Touches hiring, HR, or workforce decisions."
      },
      "Sensitive/Biometric": {
        "meaning": "Processes biometric or special-category data."
      },
      "Financial": {
        "meaning": "Touches financial markets, payments, or money movement."
      },
      "Content&IP": {
        "meaning": "Generates, ingests, or stores copyrightable content."
      },
      "Safety&Physical": {
        "meaning": "Can cause physical harm or governs physical systems."
      },
      "Infrastructure": {
        "meaning": "Operates critical or backbone infrastructure."
      },
      "Minors": {
        "meaning": "Accessible to or directed at users under 18."
      }
    },
    "subcats": {
      "CNS": {
        "harm_mechanism": "Consent & contract formation (browsewrap, dark patterns, cancellation, auto-renewal)"
      },
      "LIA": {
        "harm_mechanism": "Liability caps, warranty disclaimers, product-vs-service classification, agent/credential misuse, runaway-agent financial commitment, wasted costs, negligence defense"
      },
      "HAL": {
        "harm_mechanism": "Hallucination, defamation, false output, agent impersonation, bot accountability for fabricated promises"
      },
      "INF": {
        "harm_mechanism": "IP infringement — copyright, training data, fair use collapse, RAG substitution, safe harbor loss, deepfake takedown, watermarking, internal IP contamination"
      },
      "PRV": {
        "harm_mechanism": "Privacy & data protection — cross-border transfer, sub-processor liability, retention, breach notification, over-scope processing, CPRA service provider, DPDP duties"
      },
      "BIO": {
        "harm_mechanism": "Biometric harvesting & consent (BIPA, CUBI, voiceprints, diarization)"
      },
      "DEC": {
        "harm_mechanism": "Automated decision-making harms — bias, CRA classification, HR/healthcare decisions, high-risk AI, DPIA/FRIA failure, missing HITL, GDPR Art. 22"
      },
      "HRM": {
        "harm_mechanism": "Direct user harm — minors, companions, healthcare impersonation, wrongful death, psychological manipulation"
      },
      "FRD": {
        "harm_mechanism": "Fraud & misrepresentation — AI washing, evidence fabrication, vendor-risk flow-down, SEC enforcement"
      },
      "TRD": {
        "harm_mechanism": "Trading, pricing, market manipulation — algo trading, algorithmic collusion, SEBI, Sherman Act"
      }
    },
    "lanes": {
      "A": {
        "meaning": "Agentic Shield — exposure for external AI **product builders** (the thing they ship)."
      },
      "B": {
        "meaning": "Workplace Shield — exposure from **internal AI use** inside an organization."
      },
      "Both": {
        "meaning": "Applies to both lanes."
      }
    },
    "pain_tiers": {
      "T1": {
        "name": "EXTINCTION",
        "definition": "Business cannot continue. Forced teardown, permanent regulatory ban, total liquidation, model destruction, wrongful death."
      },
      "T2": {
        "name": "UNCAPPED MONEY",
        "definition": "Business continues but financial exposure has no ceiling. Every incident adds uncapped cost. Revenue-percentage penalty structures land here."
      },
      "T3": {
        "name": "DEAL DEATH",
        "definition": "Money is capped but enterprise deals stop closing. Regional market access narrows. Per-violation bounded penalties."
      },
      "T4": {
        "name": "REGULATORY HEAT",
        "definition": "Fines, enforcement action, forced operational changes. Expensive but survivable."
      },
      "T5": {
        "name": "FRICTION",
        "definition": "Pending legislation, documentation gaps, preemption uncertainty. Annoying, not existential."
      }
    },
    "pain_depth": {
      "Corporate": {
        "definition": "LLC shield holds. Business loses money but founder's personal assets safe."
      },
      "Personal": {
        "definition": "Shield pierces. Founder personally on the hook. Personal guarantees, agency-theory principals, direct tort exposure."
      },
      "Criminal": {
        "definition": "Beyond civil. Fraud charges, perjury, criminal negligence."
      }
    },
    "velocity": {
      "ACTIVE_NOW": {
        "definition": "Law active AND immediate consequence on first incident."
      },
      "THIS_YEAR": {
        "definition": "Law active but enforcement takes 6–18 months to materialize."
      },
      "INCOMING": {
        "definition": "T3–T5 threats with known effective date 2+ months out, OR T1–T2 threats more than 12 months out."
      },
      "WATCH": {
        "definition": "Pending legislation/advisory with no known effective date. Pairs with `Status = Pending`."
      }
    },
    "statuses": [
      "Active",
      "Upcoming",
      "Pending"
    ]
  },
