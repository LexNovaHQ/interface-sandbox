{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stage6aModelOverlay.schema.json",
  "title": "Stage 6A Model Overlay",
  "description": "Intermediate bounded model overlay for Stage 6A Legal Cartography. The model may classify existing deterministic IDs only; it may not create documents, sections, sources, locators, quotes, prose, or legal conclusions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stage6a_model_overlay_version",
    "section_classification_overlay",
    "document_relationship_overlay",
    "document_control_overlay",
    "document_mismatch_overlay",
    "feature_section_overlay",
    "overlay_limitations"
  ],
  "properties": {
    "stage6a_model_overlay_version": { "const": "stage6a_model_overlay_v1" },
    "section_classification_overlay": {
      "type": "array",
      "items": { "$ref": "#/$defs/sectionClassificationOverlayItem" }
    },
    "document_relationship_overlay": {
      "type": "array",
      "items": { "$ref": "#/$defs/documentRelationshipOverlayItem" }
    },
    "document_control_overlay": {
      "type": "array",
      "items": { "$ref": "#/$defs/documentControlOverlayItem" }
    },
    "document_mismatch_overlay": {
      "type": "array",
      "items": { "$ref": "#/$defs/documentMismatchOverlayItem" }
    },
    "feature_section_overlay": {
      "type": "array",
      "items": { "$ref": "#/$defs/featureSectionOverlayItem" }
    },
    "overlay_limitations": {
      "type": "array",
      "items": { "$ref": "#/$defs/overlayLimitationItem" }
    }
  },
  "$defs": {
    "signal": {
      "type": "string",
      "enum": ["visible", "not_visible", "partial", "conflicting", "not_applicable", "unknown"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "unknown"]
    },
    "sectionFunction": {
      "type": "string",
      "enum": [
        "definitions",
        "service_description",
        "ai_disclosure",
        "privacy_notice",
        "data_processing_terms",
        "subprocessor_terms",
        "acceptable_use_rules",
        "prohibited_use_rules",
        "security_terms",
        "breach_terms",
        "retention_deletion_terms",
        "rights_request_terms",
        "cross_border_transfer_terms",
        "liability_terms",
        "warranty_disclaimer",
        "sla_terms",
        "agentic_controls",
        "commercial_terms",
        "dispute_terms",
        "other",
        "unknown"
      ]
    },
    "controlFamily": {
      "type": "string",
      "enum": [
        "ai_disclosure",
        "hallucination_disclaimer",
        "hitl_mandate",
        "acceptable_use",
        "prohibited_use",
        "privacy_notice",
        "data_collection",
        "data_use",
        "data_sharing",
        "subprocessor_disclosure",
        "model_provider_disclosure",
        "training_or_finetuning",
        "retention",
        "deletion",
        "data_subject_rights",
        "consent_withdrawal",
        "grievance_channel",
        "security_safeguards",
        "breach_notice",
        "cross_border_transfer",
        "liability_cap",
        "warranty_disclaimer",
        "sla_performance",
        "agentic_controls",
        "unknown"
      ]
    },
    "relationshipType": {
      "type": "string",
      "enum": [
        "incorporates_by_reference",
        "supplements",
        "controls_on_conflict",
        "linked_from",
        "defines_terms_for",
        "activates_when",
        "supersedes_for_subject_matter",
        "unknown"
      ]
    },
    "mismatchType": {
      "type": "string",
      "enum": [
        "feature_without_control_section",
        "doc_without_required_section",
        "conflicting_document_signal",
        "missing_core_document",
        "missing_supplemental_document",
        "control_signal_unclear",
        "unknown"
      ]
    },
    "refType": {
      "type": "string",
      "enum": ["feature", "document", "document_section", "control_signal", "source_record", "unknown"]
    },
    "basisCode": {
      "type": "string",
      "enum": [
        "heading_classification",
        "source_text_classification",
        "source_bundle_record_ref",
        "stage5_feature_ref",
        "stage6_section_ref",
        "stage6_control_signal_ref",
        "document_relationship_signal",
        "absence_after_search",
        "unknown"
      ]
    },
    "idString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "basisCodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/basisCode" },
      "uniqueItems": true
    },
    "sectionClassificationOverlayItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section_id", "section_function", "control_families", "coverage_signal", "basis_codes", "confidence"],
      "properties": {
        "section_id": { "$ref": "#/$defs/idString" },
        "section_function": { "$ref": "#/$defs/sectionFunction" },
        "control_families": {
          "type": "array",
          "items": { "$ref": "#/$defs/controlFamily" },
          "uniqueItems": true
        },
        "coverage_signal": { "$ref": "#/$defs/signal" },
        "basis_codes": { "$ref": "#/$defs/basisCodes" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "documentRelationshipOverlayItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relationship_id", "from_doc_id", "to_doc_id", "from_section_id", "to_section_id", "relationship_type", "relationship_signal", "section_refs", "basis_codes", "confidence"],
      "properties": {
        "relationship_id": { "$ref": "#/$defs/idString" },
        "from_doc_id": { "$ref": "#/$defs/idString" },
        "to_doc_id": { "$ref": "#/$defs/idString" },
        "from_section_id": { "$ref": "#/$defs/idString" },
        "to_section_id": { "$ref": "#/$defs/idString" },
        "relationship_type": { "$ref": "#/$defs/relationshipType" },
        "relationship_signal": { "$ref": "#/$defs/signal" },
        "section_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/idString" },
          "uniqueItems": true
        },
        "basis_codes": { "$ref": "#/$defs/basisCodes" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "documentControlOverlayItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section_id", "control_family", "coverage_signal", "feature_refs", "data_flow_refs", "basis_codes", "confidence"],
      "properties": {
        "section_id": { "$ref": "#/$defs/idString" },
        "control_family": { "$ref": "#/$defs/controlFamily" },
        "coverage_signal": { "$ref": "#/$defs/signal" },
        "feature_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/idString" },
          "uniqueItems": true
        },
        "data_flow_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/idString" },
          "uniqueItems": true
        },
        "basis_codes": { "$ref": "#/$defs/basisCodes" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "documentMismatchOverlayItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mismatch_id", "mismatch_type", "left_ref_type", "left_ref", "right_ref_type", "right_ref", "control_family", "mismatch_signal", "basis_codes", "confidence"],
      "properties": {
        "mismatch_id": { "$ref": "#/$defs/idString" },
        "mismatch_type": { "$ref": "#/$defs/mismatchType" },
        "left_ref_type": { "$ref": "#/$defs/refType" },
        "left_ref": { "$ref": "#/$defs/idString" },
        "right_ref_type": { "$ref": "#/$defs/refType" },
        "right_ref": { "$ref": "#/$defs/idString" },
        "control_family": { "$ref": "#/$defs/controlFamily" },
        "mismatch_signal": { "$ref": "#/$defs/signal" },
        "basis_codes": { "$ref": "#/$defs/basisCodes" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "featureSectionOverlayItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature_id", "section_ids", "control_families", "basis_codes", "confidence"],
      "properties": {
        "feature_id": { "$ref": "#/$defs/idString" },
        "section_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/idString" },
          "uniqueItems": true
        },
        "control_families": {
          "type": "array",
          "items": { "$ref": "#/$defs/controlFamily" },
          "uniqueItems": true
        },
        "basis_codes": { "$ref": "#/$defs/basisCodes" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "overlayLimitationItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["limitation_id", "scope", "reason_code", "impact_code", "confidence"],
      "properties": {
        "limitation_id": { "$ref": "#/$defs/idString" },
        "scope": {
          "type": "string",
          "enum": ["section_classification", "document_relationship", "document_control", "document_mismatch", "feature_section", "unknown"]
        },
        "reason_code": {
          "type": "string",
          "enum": ["insufficient_text_window", "section_ref_missing", "feature_ref_missing", "low_confidence_inference", "source_conflicting", "unknown"]
        },
        "impact_code": {
          "type": "string",
          "enum": ["classification_unknown", "relationship_unknown", "control_signal_unknown", "feature_mapping_unknown", "reduces_confidence", "unknown"]
        },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    }
  }
}
