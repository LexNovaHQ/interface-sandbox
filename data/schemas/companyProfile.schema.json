{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://interface-sandbox.local/schemas/companyProfile.schema.json",
  "title": "Canonical Target Profile",
  "description": "Stage 4 canonical target_profile_v2. This is the identity, jurisdiction, market, product-baseline, data-touchpoint, and Vault-baseline-candidate layer for downstream feature mapping, legal stack review, registry evaluation, and deterministic Vault assembly. The file name is retained for runtime compatibility, but the object is target_profile_v2, not legacy company_profile_v1.",
  "type": "object",
  "required": [
    "target_profile_version",
    "identity",
    "jurisdiction",
    "business_model",
    "market_context",
    "product_baseline",
    "data_touchpoint_map",
    "vault_baseline_candidates",
    "pipeline_assumptions",
    "evidence",
    "limitations"
  ],
  "additionalProperties": false,
  "properties": {
    "target_profile_version": { "const": "target_profile_v2" },
    "identity": {
      "type": "object",
      "required": [
        "brand_name",
        "legal_name",
        "trade_names",
        "website",
        "domain",
        "entity_type",
        "entity_type_family",
        "corporate_status_signal",
        "operator_or_controller_signal",
        "identity_confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "brand_name": { "type": "string" },
        "legal_name": { "type": "string" },
        "trade_names": { "type": "array", "items": { "type": "string" } },
        "website": { "type": "string" },
        "domain": { "type": "string" },
        "entity_type": { "type": "string" },
        "entity_type_family": { "type": "string", "enum": ["india", "us", "eu_uk", "other", "unknown"] },
        "corporate_status_signal": { "type": "string" },
        "operator_or_controller_signal": { "type": "string" },
        "identity_confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "jurisdiction": {
      "type": "object",
      "required": [
        "registered_or_notice_country",
        "registered_or_notice_state",
        "city",
        "full_address",
        "governing_law_country",
        "governing_law_state",
        "courts_or_venue",
        "source_basis",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "registered_or_notice_country": { "type": "string" },
        "registered_or_notice_state": { "type": "string" },
        "city": { "type": "string" },
        "full_address": { "type": "string" },
        "governing_law_country": { "type": "string" },
        "governing_law_state": { "type": "string" },
        "courts_or_venue": { "type": "string" },
        "source_basis": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "business_model": {
      "type": "object",
      "required": [
        "business_category",
        "primary_customer_type",
        "market_type_candidate",
        "sales_motion",
        "revenue_model_signal",
        "enterprise_or_self_serve_signal",
        "public_sector_signal",
        "business_model_confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "business_category": { "type": "string" },
        "primary_customer_type": { "type": "string" },
        "market_type_candidate": { "type": "string", "enum": ["b2b", "b2c", "hybrid", "unknown"] },
        "sales_motion": { "type": "string" },
        "revenue_model_signal": { "type": "string" },
        "enterprise_or_self_serve_signal": { "type": "string" },
        "public_sector_signal": { "type": "string" },
        "business_model_confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "market_context": {
      "type": "object",
      "required": ["industry", "target_geographies", "target_languages", "regulated_sector_hints", "market_context_confidence"],
      "additionalProperties": false,
      "properties": {
        "industry": { "type": "string" },
        "target_geographies": { "type": "array", "items": { "type": "string" } },
        "target_languages": { "type": "array", "items": { "type": "string" } },
        "regulated_sector_hints": { "type": "array", "items": { "type": "string" } },
        "market_context_confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "product_baseline": {
      "type": "object",
      "required": [
        "high_level_offering",
        "primary_claim",
        "products",
        "delivery_app_candidate",
        "delivery_api_candidate",
        "beta_or_preview_signal",
        "integration_candidates"
      ],
      "additionalProperties": false,
      "properties": {
        "high_level_offering": { "type": "string" },
        "primary_claim": { "type": "string" },
        "products": { "type": "array", "items": { "$ref": "#/$defs/productCandidate" } },
        "delivery_app_candidate": { "$ref": "#/$defs/triState" },
        "delivery_api_candidate": { "$ref": "#/$defs/triState" },
        "beta_or_preview_signal": { "type": "string" },
        "integration_candidates": { "type": "array", "items": { "$ref": "#/$defs/integrationCandidate" } }
      }
    },
    "data_touchpoint_map": {
      "type": "array",
      "items": { "$ref": "#/$defs/dataTouchpoint" }
    },
    "vault_baseline_candidates": {
      "type": "object",
      "required": ["baseline", "compliance"],
      "additionalProperties": false,
      "properties": {
        "baseline": {
          "type": "object",
          "required": [
            "company",
            "entity_type",
            "address",
            "legal_email",
            "privacy_email",
            "products",
            "jurisdiction",
            "market",
            "delivery",
            "revenue_model",
            "has_beta",
            "integrations"
          ],
          "additionalProperties": false,
          "properties": {
            "company": { "$ref": "#/$defs/vaultCandidate" },
            "entity_type": { "$ref": "#/$defs/vaultCandidate" },
            "address": { "$ref": "#/$defs/vaultCandidate" },
            "legal_email": { "$ref": "#/$defs/vaultCandidate" },
            "privacy_email": { "$ref": "#/$defs/vaultCandidate" },
            "products": { "$ref": "#/$defs/vaultCandidate" },
            "jurisdiction": {
              "type": "object",
              "required": ["country", "state"],
              "additionalProperties": false,
              "properties": {
                "country": { "$ref": "#/$defs/vaultCandidate" },
                "state": { "$ref": "#/$defs/vaultCandidate" }
              }
            },
            "market": { "$ref": "#/$defs/vaultCandidate" },
            "delivery": {
              "type": "object",
              "required": ["app", "api"],
              "additionalProperties": false,
              "properties": {
                "app": { "$ref": "#/$defs/vaultCandidate" },
                "api": { "$ref": "#/$defs/vaultCandidate" }
              }
            },
            "revenue_model": { "$ref": "#/$defs/vaultCandidate" },
            "has_beta": { "$ref": "#/$defs/vaultCandidate" },
            "integrations": {
              "type": "object",
              "required": ["slack", "crm", "stripe", "github", "webhooks", "none"],
              "additionalProperties": false,
              "properties": {
                "slack": { "$ref": "#/$defs/vaultCandidate" },
                "crm": { "$ref": "#/$defs/vaultCandidate" },
                "stripe": { "$ref": "#/$defs/vaultCandidate" },
                "github": { "$ref": "#/$defs/vaultCandidate" },
                "webhooks": { "$ref": "#/$defs/vaultCandidate" },
                "none": { "$ref": "#/$defs/vaultCandidate" }
              }
            }
          }
        },
        "compliance": {
          "type": "object",
          "required": ["processes_pii", "eu_users", "ca_users", "other_regions"],
          "additionalProperties": false,
          "properties": {
            "processes_pii": { "$ref": "#/$defs/vaultCandidate" },
            "eu_users": { "$ref": "#/$defs/vaultCandidate" },
            "ca_users": { "$ref": "#/$defs/vaultCandidate" },
            "other_regions": { "$ref": "#/$defs/vaultCandidate" }
          }
        }
      }
    },
    "pipeline_assumptions": {
      "type": "object",
      "required": ["for_feature_map", "for_legal_stack", "for_registry_matching", "for_vault", "assumption_warnings"],
      "additionalProperties": false,
      "properties": {
        "for_feature_map": { "type": "array", "items": { "type": "string" } },
        "for_legal_stack": { "type": "array", "items": { "type": "string" } },
        "for_registry_matching": { "type": "array", "items": { "type": "string" } },
        "for_vault": { "type": "array", "items": { "type": "string" } },
        "assumption_warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["field_evidence_refs", "unresolved_questions"],
      "additionalProperties": false,
      "properties": {
        "field_evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/fieldEvidenceRef" } },
        "unresolved_questions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "confidence": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
    "triState": { "type": "string", "enum": ["true", "false", "unknown"] },
    "candidateStatus": { "type": "string", "enum": ["PREFILL_READY", "CONFIRM", "UNKNOWN"] },
    "candidateValue": {
      "oneOf": [
        { "type": "string" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "array" },
        { "type": "object" },
        { "type": "null" }
      ]
    },
    "vaultCandidate": {
      "type": "object",
      "required": ["value", "status", "basis", "confidence", "evidence_refs"],
      "additionalProperties": false,
      "properties": {
        "value": { "$ref": "#/$defs/candidateValue" },
        "status": { "$ref": "#/$defs/candidateStatus" },
        "basis": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "productCandidate": {
      "type": "object",
      "required": ["name", "description", "source_url", "evidence_quote", "confidence"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "source_url": { "type": "string" },
        "evidence_quote": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "integrationCandidate": {
      "type": "object",
      "required": ["name", "source_url", "evidence_quote", "confidence"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "source_url": { "type": "string" },
        "evidence_quote": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "dataTouchpoint": {
      "type": "object",
      "required": ["touchpoint_id", "actor", "data_subject", "data_category", "collection_or_processing_context", "source_url", "evidence_quote", "confidence"],
      "additionalProperties": false,
      "properties": {
        "touchpoint_id": { "type": "string" },
        "actor": { "type": "string", "enum": ["end_user", "customer_admin", "enterprise_customer", "developer", "third_party", "unknown"] },
        "data_subject": { "type": "string", "enum": ["user", "customer", "employee", "consumer", "developer", "child", "unknown"] },
        "data_category": { "type": "string", "enum": ["account", "contact", "prompt", "uploaded_file", "generated_output", "usage_log", "payment", "support", "sensitive", "unknown"] },
        "collection_or_processing_context": { "type": "string" },
        "source_url": { "type": "string" },
        "evidence_quote": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "fieldEvidenceRef": {
      "type": "object",
      "required": ["field_path", "evidence_source_id", "source_url", "claim_supported", "evidence_quote", "confidence"],
      "additionalProperties": false,
      "properties": {
        "field_path": { "type": "string" },
        "evidence_source_id": { "type": "string" },
        "source_url": { "type": "string" },
        "claim_supported": { "type": "string" },
        "evidence_quote": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    }
  }
}
