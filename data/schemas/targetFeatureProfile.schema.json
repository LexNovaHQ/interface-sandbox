{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://interface-sandbox.local/schemas/targetFeatureProfile.schema.json",
  "title": "Feature Profile",
  "description": "Stage 5 canonical feature_profile_v2. Full clean_text_lossless remains in the stage packet. Model proof uses compact evidence_refs citations; evidence_quote is optional legacy/runtime-resolved text only. Completeness is source-coverage based and nonblocking at runtime. Stage 5 Batch 1 adds feature classification quality metadata and unresolved feature candidates for capped reinvestigation/degraded fallback.",
  "type": "object",
  "required": ["feature_profile_version", "target_profile_ref", "feature_inventory", "product_feature_map", "data_provenance_map", "regulated_surface_map", "architecture_hints", "commercial_scan", "vault_feature_candidates", "evidence", "limitations"],
  "additionalProperties": false,
  "properties": {
    "feature_profile_version": { "const": "feature_profile_v2" },
    "target_profile_ref": { "type": "object", "required": ["target_profile_version", "brand_name", "legal_name", "domain"], "additionalProperties": false, "properties": { "target_profile_version": { "type": "string" }, "brand_name": { "type": "string" }, "legal_name": { "type": "string" }, "domain": { "type": "string" } } },
    "feature_inventory": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/feature" } },
    "product_feature_map": { "description": "Legacy compatibility alias. Must be empty; feature_inventory[] is canonical.", "type": "array", "maxItems": 0 },
    "data_provenance_map": { "type": "array", "items": { "$ref": "#/$defs/flatDataProvenance" } },
    "regulated_surface_map": { "type": "array", "items": { "$ref": "#/$defs/regulatedSurface" } },
    "architecture_hints": { "type": "array", "items": { "$ref": "#/$defs/architectureHint" } },
    "classification_quality": { "$ref": "#/$defs/classificationQuality" },
    "unresolved_feature_candidates": { "type": "array", "items": { "$ref": "#/$defs/unresolvedFeatureCandidate" } },
    "commercial_scan": {
      "type": "object",
      "required": ["distinct_commercial_outcomes_seen", "mapped_core_feature_ids", "source_coverage", "unmapped_outcomes_due_to_insufficient_detail", "completeness_status", "completeness_warnings"],
      "additionalProperties": false,
      "properties": {
        "distinct_commercial_outcomes_seen": { "type": "array", "items": { "type": "string" } },
        "mapped_core_feature_ids": { "type": "array", "items": { "type": "string" } },
        "source_coverage": { "type": "array", "items": { "$ref": "#/$defs/sourceCoverage" } },
        "unmapped_outcomes_due_to_insufficient_detail": { "type": "array", "items": { "type": "string" } },
        "completeness_status": { "type": "string", "enum": ["COMPLETE", "PARTIAL", "THIN"] },
        "completeness_warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "vault_feature_candidates": { "type": "object", "required": ["baseline", "archetypes", "compliance"], "additionalProperties": false, "properties": { "baseline": { "type": "object", "additionalProperties": true }, "archetypes": { "type": "object", "additionalProperties": true }, "compliance": { "type": "object", "additionalProperties": true } } },
    "evidence": { "type": "object", "required": ["field_evidence_refs", "unresolved_questions"], "additionalProperties": false, "properties": { "field_evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/fieldEvidenceRef" } }, "unresolved_questions": { "type": "array", "items": { "type": "string" } } } },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "confidence": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
    "triState": { "type": "string", "enum": ["true", "false", "unknown"] },
    "evidenceRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "optionalQuote": { "type": "string", "description": "Optional legacy/runtime-resolved quote. Model should cite evidence_refs instead of copying verbatim quotes." },
    "dataCategory": { "type": "string", "enum": ["prompt", "account", "contact", "uploaded_file", "generated_output", "audio", "text", "document", "image", "video", "code", "api_payload", "payment", "usage_log", "support", "sensitive", "unknown"] },
    "classificationQuality": { "type": "object", "required": ["quality_version", "status", "reinvestigation_required", "reinvestigation_attempted", "reinvestigation_pass_count", "unresolved_feature_count", "fallback_routing_required"], "additionalProperties": false, "properties": { "quality_version": { "type": "string" }, "status": { "type": "string", "enum": ["PASS", "REINVESTIGATION_REQUIRED", "DEGRADED"] }, "reinvestigation_required": { "type": "boolean" }, "reinvestigation_attempted": { "type": "boolean" }, "reinvestigation_pass_count": { "type": "integer", "minimum": 0, "maximum": 1 }, "unresolved_feature_count": { "type": "integer", "minimum": 0 }, "fallback_routing_required": { "type": "boolean" } } },
    "unresolvedFeatureCandidate": { "type": "object", "required": ["candidate_id", "candidate_name", "reason", "evidence_refs", "recommended_downstream_handling"], "additionalProperties": false, "properties": { "candidate_id": { "type": "string" }, "candidate_name": { "type": "string" }, "previous_feature_id": { "type": ["string", "null"] }, "reason": { "type": "string" }, "source_url": { "type": ["string", "null"] }, "evidence_refs": { "type": "array", "items": { "type": "string" } }, "recommended_downstream_handling": { "type": "string" } } },
    "feature": { "type": "object", "required": ["feature_id", "feature_name", "feature_role", "commercial_function", "business_label_or_product_area", "feature_description", "actor_or_user", "input_data", "system_action", "output_or_result", "autonomy_level", "human_review_signal", "external_action_signal", "delivery_channels", "data_provenance", "archetype_codes", "archetype_labels", "archetype_provenance", "surface_tokens", "surface_provenance", "confidence", "feature_source_url", "evidence_refs", "linked_threat_ids"], "additionalProperties": false, "properties": { "feature_id": { "type": "string" }, "feature_name": { "type": "string" }, "feature_role": { "type": "string", "enum": ["CORE", "SECONDARY"] }, "commercial_function": { "type": "string" }, "business_label_or_product_area": { "type": "string" }, "feature_description": { "type": "string" }, "actor_or_user": { "type": "string" }, "input_data": { "type": "array", "items": { "type": "string" } }, "system_action": { "type": "string" }, "output_or_result": { "type": "string" }, "autonomy_level": { "type": "string", "enum": ["none", "draft", "recommend", "execute", "unknown"] }, "human_review_signal": { "type": "string", "enum": ["required", "optional", "not_visible", "unknown"] }, "external_action_signal": { "$ref": "#/$defs/triState" }, "delivery_channels": { "type": "object", "required": ["app", "api", "web"], "additionalProperties": false, "properties": { "app": { "$ref": "#/$defs/triState" }, "api": { "$ref": "#/$defs/triState" }, "web": { "$ref": "#/$defs/triState" } } }, "data_provenance": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/dataProvenance" } }, "archetype_codes": { "type": "array", "items": { "type": "string" } }, "archetype_labels": { "type": "array", "items": { "type": "string" } }, "archetype_provenance": { "type": "array", "items": { "$ref": "#/$defs/archetypeProvenance" } }, "surface_tokens": { "type": "array", "items": { "type": "string" } }, "surface_provenance": { "type": "array", "items": { "$ref": "#/$defs/surfaceProvenance" } }, "confidence": { "$ref": "#/$defs/confidence" }, "feature_source_url": { "type": "string" }, "evidence_refs": { "$ref": "#/$defs/evidenceRefs" }, "evidence_quote": { "$ref": "#/$defs/optionalQuote" }, "linked_threat_ids": { "type": "array", "items": { "type": "string" } } } },
    "dataProvenance": { "type": "object", "required": ["data_origin", "data_subject", "data_category", "processing_context", "storage_or_retention_signal", "training_or_finetuning_signal", "source_url", "evidence_refs", "confidence"], "additionalProperties": false, "properties": { "data_origin": { "type": "string", "enum": ["user_provided", "customer_provided", "third_party_source", "public_web", "system_generated", "unknown"] }, "data_subject": { "type": "string", "enum": ["user", "customer", "employee", "consumer", "developer", "child", "business_entity", "unknown"] }, "data_category": { "$ref": "#/$defs/dataCategory" }, "processing_context": { "type": "string" }, "storage_or_retention_signal": { "type": "string" }, "training_or_finetuning_signal": { "type": "string" }, "source_url": { "type": "string" }, "evidence_refs": { "$ref": "#/$defs/evidenceRefs" }, "evidence_quote": { "$ref": "#/$defs/optionalQuote" }, "confidence": { "$ref": "#/$defs/confidence" } } },
    "flatDataProvenance": { "type": "object", "required": ["provenance_id", "feature_id", "data_origin", "data_subject", "data_category", "processing_context", "storage_or_retention_signal", "training_or_finetuning_signal", "source_url", "evidence_refs", "confidence"], "additionalProperties": false, "properties": { "provenance_id": { "type": "string" }, "feature_id": { "type": "string" }, "data_origin": { "type": "string" }, "data_subject": { "type": "string" }, "data_category": { "$ref": "#/$defs/dataCategory" }, "processing_context": { "type": "string" }, "storage_or_retention_signal": { "type": "string" }, "training_or_finetuning_signal": { "type": "string" }, "source_url": { "type": "string" }, "evidence_refs": { "$ref": "#/$defs/evidenceRefs" }, "evidence_quote": { "$ref": "#/$defs/optionalQuote" }, "confidence": { "$ref": "#/$defs/confidence" } } },
    "archetypeProvenance": { "type": "object", "required": ["archetype_code", "registry_key_detection_logic", "matched_feature_behavior", "source_url", "evidence_refs", "confidence"], "additionalProperties": false, "properties": { "archetype_code": { "type": "string" }, "registry_key_detection_logic": { "type": "string" }, "matched_feature_behavior": { "type": "string" }, "source_url": { "type": "string" }, "evidence_refs": { "$ref": "#/$defs/evidenceRefs" }, "evidence_quote": { "$ref": "#/$defs/optionalQuote" }, "confidence": { "$ref": "#/$defs/confidence" } } },
    "surfaceProvenance": { "type": "object", "required": ["surface_token", "registry_key_surface_meaning", "matched_data_or_context", "source_url", "evidence_refs", "confidence"], "additionalProperties": false, "properties": { "surface_token": { "type": "string" }, "registry_key_surface_meaning": { "type": "string" }, "matched_data_or_context": { "type": "string" }, "source_url": { "type": "string" }, "evidence_refs": { "$ref": "#/$defs/evidenceRefs" }, "evidence_quote": { "$ref": "#/$defs/optionalQuote" }, "confidence": { "$ref": "#/$defs/confidence" } } },
    "regulatedSurface": { "type": "object", "required": ["surface_id", "feature_id", "surface_token", "int_ext_classification", "basis", "confidence", "evidence_refs"], "additionalProperties": false, "properties": { "surface_id": { "type": "string" }, "feature_id": { "type": "string" }, "surface_token": { "type": "string" }, "int_ext_classification": { "type": "string", "enum": ["internal", "external", "both", "unknown"] }, "basis": { "type": "string" }, "confidence": { "$ref": "#/$defs/confidence" }, "evidence_refs": { "$ref": "#/$defs/evidenceRefs" } } },
    "architectureHint": { "type": "object", "required": ["hint_id", "feature_id", "hint_type", "hint_value", "disposition", "source_url", "evidence_refs", "confidence"], "additionalProperties": false, "properties": { "hint_id": { "type": "string" }, "feature_id": { "type": "string" }, "hint_type": { "type": "string", "enum": ["memory", "model_provider", "cloud_host", "vector_db", "subprocessor", "integration", "unknown"] }, "hint_value": { "type": "string" }, "disposition": { "type": "string", "enum": ["prefill_candidate", "confirmation_only", "ignore"] }, "source_url": { "type": "string" }, "evidence_refs": { "$ref": "#/$defs/evidenceRefs" }, "evidence_quote": { "$ref": "#/$defs/optionalQuote" }, "confidence": { "$ref": "#/$defs/confidence" } } },
    "sourceCoverage": { "type": "object", "required": ["source_id", "source_url", "source_family", "coverage_status", "mapped_feature_ids", "unmapped_reason", "evidence_refs"], "additionalProperties": false, "properties": { "source_id": { "type": "string" }, "source_url": { "type": "string" }, "source_family": { "type": "string" }, "coverage_status": { "type": "string", "enum": ["mapped", "supporting", "duplicate", "insufficient_detail", "non_feature_context"] }, "mapped_feature_ids": { "type": "array", "items": { "type": "string" } }, "unmapped_reason": { "type": "string" }, "evidence_refs": { "$ref": "#/$defs/evidenceRefs" } } },
    "fieldEvidenceRef": { "type": "object", "required": ["field_path", "evidence_refs", "basis", "confidence"], "additionalProperties": false, "properties": { "field_path": { "type": "string" }, "evidence_refs": { "$ref": "#/$defs/evidenceRefs" }, "basis": { "type": "string" }, "confidence": { "$ref": "#/$defs/confidence" } } }
  }
}
