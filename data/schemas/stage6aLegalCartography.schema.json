{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://interface-sandbox.local/schemas/stage6aLegalCartography.schema.json",
  "title": "Stage 6A Legal Cartography",
  "description": "Canonical Stage 6A output contract. Legal cartography only. No legacy legal_stack fields. No 6B data provenance profile. No Stage 7 threat decisions.",
  "type": "object",
  "required": [
    "legal_stack_review_version",
    "stage_role",
    "input_refs",
    "legal_document_cartography",
    "stage7_navigation_index",
    "stage6_limitations"
  ],
  "additionalProperties": false,
  "properties": {
    "legal_stack_review_version": { "const": "legal_stack_review_v2" },
    "stage_role": { "const": "stage7_navigation_index" },
    "input_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target_profile_version": { "type": "string" },
        "feature_profile_version": { "type": "string" },
        "source_bundle_version": { "type": "string" },
        "target_profile_ref": { "type": ["string", "object", "null"], "additionalProperties": true },
        "feature_profile_ref": { "type": ["string", "object", "null"], "additionalProperties": true }
      }
    },
    "legal_document_cartography": { "$ref": "#/$defs/legalDocumentCartography" },
    "stage7_navigation_index": { "$ref": "#/$defs/stage7NavigationIndex6A" },
    "stage6_limitations": {
      "type": "array",
      "items": { "$ref": "#/$defs/stage6Limitation" }
    }
  },
  "$defs": {
    "signal": {
      "type": "string",
      "enum": ["visible", "not_visible", "partial", "conflicting", "not_applicable", "unknown"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "unknown"]
    },
    "documentStatus": {
      "type": "string",
      "enum": ["visible", "not_visible", "partial", "conflicting", "not_applicable", "unknown", "ingested", "absent", "access_failed", "insufficient"]
    },
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "basisCode": {
      "type": "string",
      "enum": [
        "source_bundle_record_ref",
        "stage5_feature_ref",
        "stage5_architecture_hint",
        "stage6_legal_section_ref",
        "stage6_control_signal_ref",
        "direct_policy_signal",
        "indirect_policy_signal",
        "absence_after_search",
        "heading_classification",
        "source_metadata",
        "unknown"
      ]
    },
    "docType": {
      "type": "string",
      "enum": [
        "tos",
        "privacy_policy",
        "dpa",
        "aup",
        "sla",
        "eula",
        "cookie_policy",
        "subprocessor_page",
        "security_page",
        "trust_center",
        "status_page",
        "ai_policy",
        "responsible_ai_page",
        "model_card",
        "developer_terms",
        "api_terms",
        "community_guidelines",
        "data_deletion_page",
        "dsr_page",
        "grievance_page",
        "baa",
        "hipaa_notice",
        "data_transfer_addendum",
        "other_valid_control_doc",
        "unknown"
      ]
    },
    "controlFamily": {
      "type": "string",
      "enum": [
        "ai_disclosure",
        "hallucination_disclaimer",
        "hitl_mandate",
        "acceptable_use",
        "prohibited_use",
        "privacy_notice",
        "data_collection",
        "data_use",
        "data_sharing",
        "subprocessor_disclosure",
        "model_provider_disclosure",
        "training_or_finetuning",
        "retention",
        "deletion",
        "data_subject_rights",
        "consent_withdrawal",
        "grievance_channel",
        "security_safeguards",
        "breach_notice",
        "cross_border_transfer",
        "liability_cap",
        "warranty_disclaimer",
        "sla_performance",
        "agentic_controls",
        "commercial_terms",
        "dispute_terms",
        "unknown"
      ]
    },
    "sectionFunction": {
      "type": "string",
      "enum": [
        "definitions",
        "service_description",
        "ai_disclosure",
        "privacy_notice",
        "data_processing_terms",
        "subprocessor_terms",
        "acceptable_use_rules",
        "prohibited_use_rules",
        "security_terms",
        "breach_terms",
        "retention_deletion_terms",
        "rights_request_terms",
        "cross_border_transfer_terms",
        "liability_terms",
        "warranty_disclaimer",
        "sla_terms",
        "agentic_controls",
        "commercial_terms",
        "dispute_terms",
        "other",
        "unknown"
      ]
    },
    "structuralZone": {
      "type": "string",
      "enum": ["main_body", "annexure", "schedule", "exhibit", "table", "appendix", "linked_policy", "footer_notice", "banner_notice", "modal_notice", "faq", "unknown"]
    },
    "locatorType": {
      "type": "string",
      "enum": ["heading_path", "url_fragment", "text_anchor", "source_record", "page_url", "chunk_index", "unknown"]
    },
    "sourceType": {
      "type": "string",
      "enum": ["legal_document", "privacy_document", "terms_document", "security_document", "trust_document", "status_document", "feature_source", "public_page", "api_doc", "help_doc", "source_bundle_record", "unknown"]
    },
    "reasonForFallback": {
      "type": "string",
      "enum": ["direct_source_verification_required", "stage6_signal_unknown", "stage6_signal_conflicting", "missing_document_section_ref", "hunter_trigger_requires_line_read", "source_locator_available", "source_scope_incomplete", "unindexed_admitted_source", "unknown"]
    },
    "absenceBasis": {
      "type": "string",
      "enum": ["searched_legal_docs", "searched_privacy_docs", "searched_security_docs", "searched_trust_docs", "searched_public_sources", "source_not_available", "access_failed", "not_enough_context", "unknown"]
    },
    "legalDocumentCartography": {
      "type": "object",
      "required": [
        "legal_document_inventory",
        "legal_document_index",
        "document_relationship_map",
        "document_control_signal_map",
        "document_mismatch_signal_map",
        "legal_stack_summary_signals",
        "legal_stack_limitations"
      ],
      "additionalProperties": false,
      "properties": {
        "legal_document_inventory": { "type": "array", "items": { "$ref": "#/$defs/legalDocumentInventoryItem" } },
        "legal_document_index": { "type": "array", "items": { "$ref": "#/$defs/legalDocumentIndexItem" } },
        "document_relationship_map": { "type": "array", "items": { "$ref": "#/$defs/documentRelationshipItem" } },
        "document_control_signal_map": { "type": "array", "items": { "$ref": "#/$defs/documentControlSignalItem" } },
        "document_mismatch_signal_map": { "type": "array", "items": { "$ref": "#/$defs/documentMismatchSignalItem" } },
        "legal_stack_summary_signals": { "$ref": "#/$defs/legalStackSummarySignals" },
        "legal_stack_limitations": { "type": "array", "items": { "$ref": "#/$defs/legalStackLimitationItem" } }
      }
    },
    "legalDocumentInventoryItem": {
      "type": "object",
      "required": ["doc_id", "doc_type", "doc_family", "doc_title", "document_status", "access_status", "source_record_ref", "source_url", "canonical_or_supplemental", "confidence"],
      "additionalProperties": false,
      "properties": {
        "doc_id": { "type": "string" },
        "doc_type": { "$ref": "#/$defs/docType" },
        "doc_family": { "type": "string", "enum": ["core", "supplemental", "unknown"] },
        "doc_title": { "type": "string" },
        "document_status": { "$ref": "#/$defs/documentStatus" },
        "access_status": { "$ref": "#/$defs/documentStatus" },
        "source_record_ref": { "type": "string" },
        "source_url": { "type": "string" },
        "canonical_or_supplemental": { "type": "string", "enum": ["canonical", "supplemental", "unknown"] },
        "effective_date": { "type": "string" },
        "last_updated": { "type": "string" },
        "version": { "type": "string" },
        "jurisdiction_scope": { "$ref": "#/$defs/stringArray" },
        "language": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "legalDocumentIndexItem": {
      "type": "object",
      "required": ["index_id", "doc_id", "section_id", "section_path", "heading_level", "heading_text", "structural_zone", "section_function", "control_topics_detected", "feature_refs", "data_flow_refs", "source_record_ref", "source_locator", "confidence"],
      "additionalProperties": false,
      "properties": {
        "index_id": { "type": "string" },
        "doc_id": { "type": "string" },
        "section_id": { "type": "string" },
        "section_path": { "type": "string" },
        "heading_level": { "type": ["integer", "string"] },
        "heading_text": { "type": "string" },
        "structural_zone": { "$ref": "#/$defs/structuralZone" },
        "section_function": { "$ref": "#/$defs/sectionFunction" },
        "control_topics_detected": { "type": "array", "items": { "$ref": "#/$defs/controlFamily" } },
        "feature_refs": { "$ref": "#/$defs/stringArray" },
        "data_flow_refs": { "$ref": "#/$defs/stringArray" },
        "source_record_ref": { "type": "string" },
        "source_locator": { "$ref": "#/$defs/sourceLocator" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "sourceLocator": {
      "type": "object",
      "required": ["locator_type", "locator_value"],
      "additionalProperties": false,
      "properties": {
        "locator_type": { "$ref": "#/$defs/locatorType" },
        "locator_value": { "type": "string" }
      }
    },
    "documentRelationshipItem": {
      "type": "object",
      "required": ["relationship_id", "from_doc_id", "to_doc_id", "from_section_id", "to_section_id", "relationship_type", "relationship_signal", "section_refs", "source_record_ref", "confidence"],
      "additionalProperties": false,
      "properties": {
        "relationship_id": { "type": "string" },
        "from_doc_id": { "type": "string" },
        "to_doc_id": { "type": "string" },
        "from_section_id": { "type": "string" },
        "to_section_id": { "type": "string" },
        "relationship_type": { "type": "string", "enum": ["incorporates_by_reference", "supplements", "controls_on_conflict", "linked_from", "defines_terms_for", "activates_when", "supersedes_for_subject_matter", "embedded_within", "unknown"] },
        "relationship_signal": { "$ref": "#/$defs/signal" },
        "section_refs": { "$ref": "#/$defs/stringArray" },
        "source_record_ref": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "documentControlSignalItem": {
      "type": "object",
      "required": ["control_signal_id", "doc_id", "section_id", "control_family", "coverage_signal", "feature_refs", "data_flow_refs", "basis_codes", "source_record_ref", "confidence"],
      "additionalProperties": false,
      "properties": {
        "control_signal_id": { "type": "string" },
        "doc_id": { "type": "string" },
        "section_id": { "type": "string" },
        "control_family": { "$ref": "#/$defs/controlFamily" },
        "coverage_signal": { "$ref": "#/$defs/signal" },
        "feature_refs": { "$ref": "#/$defs/stringArray" },
        "data_flow_refs": { "$ref": "#/$defs/stringArray" },
        "basis_codes": { "type": "array", "items": { "$ref": "#/$defs/basisCode" } },
        "source_record_ref": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "documentMismatchSignalItem": {
      "type": "object",
      "required": ["mismatch_id", "mismatch_type", "left_ref_type", "left_ref", "right_ref_type", "right_ref", "control_family", "mismatch_signal", "basis_codes", "confidence"],
      "additionalProperties": false,
      "properties": {
        "mismatch_id": { "type": "string" },
        "mismatch_type": { "type": "string", "enum": ["feature_vs_document", "data_flow_vs_document", "document_vs_document", "claim_vs_absence", "stack_vs_reality", "unknown"] },
        "left_ref_type": { "type": "string", "enum": ["feature", "data_flow", "document", "document_section", "control_family", "source_record", "unknown"] },
        "left_ref": { "type": "string" },
        "right_ref_type": { "type": "string", "enum": ["feature", "data_flow", "document", "document_section", "control_family", "source_record", "absence", "unknown"] },
        "right_ref": { "type": "string" },
        "control_family": { "$ref": "#/$defs/controlFamily" },
        "mismatch_signal": { "$ref": "#/$defs/signal" },
        "basis_codes": { "type": "array", "items": { "$ref": "#/$defs/basisCode" } },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "legalStackSummarySignals": {
      "type": "object",
      "required": ["core_stack_status", "supplemental_artifact_doc_ids", "document_hierarchy_signal", "legal_stack_coverage_signal", "major_unknowns"],
      "additionalProperties": false,
      "properties": {
        "core_stack_status": {
          "type": "object",
          "required": ["tos", "privacy_policy", "dpa", "aup", "sla"],
          "additionalProperties": false,
          "properties": {
            "tos": { "$ref": "#/$defs/signal" },
            "privacy_policy": { "$ref": "#/$defs/signal" },
            "dpa": { "$ref": "#/$defs/signal" },
            "aup": { "$ref": "#/$defs/signal" },
            "sla": { "$ref": "#/$defs/signal" }
          }
        },
        "supplemental_artifact_doc_ids": { "$ref": "#/$defs/stringArray" },
        "document_hierarchy_signal": { "$ref": "#/$defs/signal" },
        "legal_stack_coverage_signal": { "$ref": "#/$defs/signal" },
        "major_unknowns": { "$ref": "#/$defs/stringArray" }
      }
    },
    "legalStackLimitationItem": {
      "type": "object",
      "required": ["limitation_id", "scope", "doc_id", "section_id", "reason_code", "impact_code", "confidence"],
      "additionalProperties": false,
      "properties": {
        "limitation_id": { "type": "string" },
        "scope": { "type": "string" },
        "doc_id": { "type": "string" },
        "section_id": { "type": "string" },
        "reason_code": { "type": "string", "enum": ["source_missing", "source_conflicting", "source_access_failed", "legal_doc_absent", "section_ref_missing", "low_confidence_classification", "unknown"] },
        "impact_code": { "type": "string", "enum": ["requires_source_line_read", "reduces_confidence", "partial_navigation_only", "fallback_packet_required", "unknown"] },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "stage7NavigationIndex6A": {
      "type": "object",
      "required": ["feature_to_document_section_index", "control_family_index", "document_source_locator_index", "absence_unknown_index", "fallback_source_packet"],
      "additionalProperties": false,
      "properties": {
        "feature_to_document_section_index": { "type": "array", "items": { "$ref": "#/$defs/featureDocumentSectionIndexItem" } },
        "control_family_index": { "type": "array", "items": { "$ref": "#/$defs/controlFamilyIndexItem" } },
        "document_source_locator_index": { "type": "array", "items": { "$ref": "#/$defs/documentSourceLocatorIndexItem" } },
        "absence_unknown_index": { "type": "array", "items": { "$ref": "#/$defs/absenceUnknownIndexItem" } },
        "fallback_source_packet": { "type": "array", "items": { "$ref": "#/$defs/fallbackSourcePacketItem" } }
      }
    },
    "featureDocumentSectionIndexItem": {
      "type": "object",
      "required": ["feature_id", "doc_ids", "section_ids", "control_families"],
      "additionalProperties": false,
      "properties": {
        "feature_id": { "type": "string" },
        "doc_ids": { "$ref": "#/$defs/stringArray" },
        "section_ids": { "$ref": "#/$defs/stringArray" },
        "control_families": { "type": "array", "items": { "$ref": "#/$defs/controlFamily" } }
      }
    },
    "controlFamilyIndexItem": {
      "type": "object",
      "required": ["control_family", "coverage_signal", "control_signal_ids", "doc_ids", "section_ids"],
      "additionalProperties": false,
      "properties": {
        "control_family": { "$ref": "#/$defs/controlFamily" },
        "coverage_signal": { "$ref": "#/$defs/signal" },
        "control_signal_ids": { "$ref": "#/$defs/stringArray" },
        "doc_ids": { "$ref": "#/$defs/stringArray" },
        "section_ids": { "$ref": "#/$defs/stringArray" }
      }
    },
    "documentSourceLocatorIndexItem": {
      "type": "object",
      "required": ["doc_id", "section_id", "source_record_ref", "source_url", "locator_type", "locator_value"],
      "additionalProperties": false,
      "properties": {
        "doc_id": { "type": "string" },
        "section_id": { "type": "string" },
        "source_record_ref": { "type": "string" },
        "source_url": { "type": "string" },
        "locator_type": { "$ref": "#/$defs/locatorType" },
        "locator_value": { "type": "string" }
      }
    },
    "absenceUnknownIndexItem": {
      "type": "object",
      "required": ["signal_type", "object_ref", "search_scope", "absence_basis", "confidence"],
      "additionalProperties": false,
      "properties": {
        "signal_type": { "type": "string", "enum": ["document_inventory", "document_section", "control_family", "feature_document_mapping", "document_relationship", "source_locator", "unknown"] },
        "object_ref": { "type": "string" },
        "search_scope": { "type": "string" },
        "absence_basis": { "$ref": "#/$defs/absenceBasis" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "fallbackSourcePacketItem": {
      "type": "object",
      "required": ["source_record_ref", "source_url", "source_type", "reason_for_fallback"],
      "additionalProperties": false,
      "properties": {
        "source_record_ref": { "type": "string" },
        "source_url": { "type": "string" },
        "source_type": { "$ref": "#/$defs/sourceType" },
        "reason_for_fallback": { "$ref": "#/$defs/reasonForFallback" }
      }
    },
    "stage6Limitation": {
      "type": "object",
      "required": ["limitation_id", "scope", "reason_code", "impact_code", "confidence"],
      "additionalProperties": false,
      "properties": {
        "limitation_id": { "type": "string" },
        "scope": { "type": "string" },
        "reason_code": { "type": "string", "enum": ["source_missing", "source_conflicting", "source_access_failed", "legal_doc_absent", "section_ref_missing", "low_confidence_classification", "unknown"] },
        "impact_code": { "type": "string", "enum": ["requires_source_line_read", "reduces_confidence", "partial_navigation_only", "fallback_packet_required", "unknown"] },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    }
  }
}
