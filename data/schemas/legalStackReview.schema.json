{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://interface-sandbox.local/schemas/legalStackReview.schema.json",
  "title": "Legal Stack Review",
  "description": "Stage 6 legal_stack_review with legacy compatibility fields plus additive 6A legal-document cartography canon.",
  "type": "object",
  "required": ["legal_stack", "document_stack_redline", "document_stack_synthesis", "legal_stack_assessment", "limitations"],
  "additionalProperties": false,
  "properties": {
    "legal_stack_review_version": { "const": "legal_stack_review_v2" },
    "stage_role": { "const": "stage7_navigation_index" },
    "input_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target_profile_version": { "type": "string" },
        "feature_profile_version": { "type": "string" },
        "source_bundle_version": { "type": "string" },
        "target_profile_ref": { "type": ["string", "object", "null"], "additionalProperties": true },
        "feature_profile_ref": { "type": ["string", "object", "null"], "additionalProperties": true }
      }
    },
    "legal_stack": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/legalDocument" }
    },
    "document_stack_redline": {
      "type": "array",
      "items": { "$ref": "#/$defs/redline" }
    },
    "document_stack_synthesis": { "type": "string" },
    "legal_stack_assessment": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "legal_document_cartography": { "$ref": "#/$defs/legalDocumentCartography" },
    "stage7_navigation_index": { "$ref": "#/$defs/stage7NavigationIndex" },
    "stage6_limitations": {
      "type": "array",
      "items": {
        "anyOf": [
          { "type": "string" },
          { "$ref": "#/$defs/stage6Limitation" }
        ]
      }
    }
  },
  "$defs": {
    "signal": {
      "type": "string",
      "enum": ["visible", "not_visible", "partial", "conflicting", "not_applicable", "unknown"]
    },
    "documentStatus": {
      "type": "string",
      "enum": ["visible", "not_visible", "partial", "conflicting", "not_applicable", "unknown", "ingested", "absent", "access_failed", "insufficient"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "unknown"]
    },
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "legalDocument": {
      "type": "object",
      "required": ["document_type", "exists", "document_url", "covers", "misses", "evidence_status", "linked_threat_ids"],
      "additionalProperties": false,
      "properties": {
        "document_type": { "type": "string", "enum": ["ToS", "Privacy Policy", "DPA", "AUP", "SLA"] },
        "exists": { "type": "boolean" },
        "document_url": { "type": "string" },
        "covers": { "type": ["array", "null"], "items": { "type": "string" } },
        "misses": { "type": "array", "items": { "type": "string" } },
        "evidence_status": { "type": "string", "enum": ["INGESTED", "ABSENT", "ACCESS_FAILED", "INSUFFICIENT"] },
        "linked_threat_ids": { "type": "array", "items": { "type": "string" } }
      },
      "allOf": [
        {
          "if": { "properties": { "exists": { "const": false } }, "required": ["exists"] },
          "then": {
            "properties": {
              "document_url": { "const": "N/A" },
              "covers": { "type": "null" }
            }
          }
        }
      ]
    },
    "redline": {
      "type": "object",
      "required": ["mismatch_id", "type", "quote", "source", "feature_ref", "claim_type", "contradicts"],
      "additionalProperties": false,
      "properties": {
        "mismatch_id": { "type": "string" },
        "type": { "type": "string", "enum": ["QUOTE_VS_QUOTE", "CLAIM_VS_ABSENCE", "STACK_VS_REALITY"] },
        "quote": { "type": "string" },
        "source": { "type": "string" },
        "feature_ref": { "type": "string" },
        "claim_type": { "type": "string" },
        "contradicts": { "type": "string" }
      }
    },
    "legalDocumentCartography": {
      "type": "object",
      "required": [
        "legal_document_inventory",
        "legal_document_index",
        "document_relationship_map",
        "document_control_signal_map",
        "document_mismatch_signal_map",
        "legal_stack_summary_signals",
        "legal_stack_limitations"
      ],
      "additionalProperties": false,
      "properties": {
        "legal_document_inventory": {
          "type": "array",
          "items": { "$ref": "#/$defs/legalDocumentInventoryItem" }
        },
        "legal_document_index": {
          "type": "array",
          "items": { "$ref": "#/$defs/legalDocumentIndexItem" }
        },
        "document_relationship_map": {
          "type": "array",
          "items": { "$ref": "#/$defs/documentRelationshipItem" }
        },
        "document_control_signal_map": {
          "type": "array",
          "items": { "$ref": "#/$defs/documentControlSignalItem" }
        },
        "document_mismatch_signal_map": {
          "type": "array",
          "items": { "$ref": "#/$defs/documentMismatchSignalItem" }
        },
        "legal_stack_summary_signals": { "$ref": "#/$defs/legalStackSummarySignals" },
        "legal_stack_limitations": {
          "type": "array",
          "items": { "$ref": "#/$defs/legalStackLimitationItem" }
        }
      }
    },
    "legalDocumentInventoryItem": {
      "type": "object",
      "required": [
        "doc_id",
        "doc_type",
        "doc_family",
        "doc_title",
        "document_status",
        "access_status",
        "source_record_ref",
        "canonical_or_supplemental",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "doc_id": { "type": "string" },
        "doc_type": {
          "type": "string",
          "enum": [
            "tos",
            "privacy_policy",
            "dpa",
            "aup",
            "sla",
            "cookie_policy",
            "subprocessor_page",
            "security_page",
            "trust_center",
            "ai_policy",
            "responsible_ai_page",
            "model_card",
            "developer_terms",
            "api_terms",
            "community_guidelines",
            "data_deletion_page",
            "dsr_page",
            "grievance_page",
            "baa",
            "hipaa_notice",
            "data_transfer_addendum",
            "other_valid_control_doc",
            "unknown"
          ]
        },
        "doc_family": { "type": "string", "enum": ["core", "supplemental", "unknown"] },
        "doc_title": { "type": "string" },
        "document_status": { "$ref": "#/$defs/documentStatus" },
        "access_status": { "$ref": "#/$defs/documentStatus" },
        "source_record_ref": { "type": "string" },
        "source_url": { "type": "string" },
        "canonical_or_supplemental": { "type": "string", "enum": ["canonical", "supplemental", "unknown"] },
        "effective_date": { "type": "string" },
        "last_updated": { "type": "string" },
        "version": { "type": "string" },
        "jurisdiction_scope": { "$ref": "#/$defs/stringArray" },
        "language": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "legalDocumentIndexItem": {
      "type": "object",
      "required": [
        "index_id",
        "doc_id",
        "section_id",
        "section_path",
        "heading_level",
        "heading_text",
        "structural_zone",
        "section_function",
        "control_topics_detected",
        "feature_refs",
        "data_flow_refs",
        "source_record_ref",
        "source_locator",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "index_id": { "type": "string" },
        "doc_id": { "type": "string" },
        "section_id": { "type": "string" },
        "section_path": { "type": "string" },
        "heading_level": { "type": ["integer", "string"], "minimum": 0 },
        "heading_text": { "type": "string" },
        "structural_zone": {
          "type": "string",
          "enum": ["main_body", "annexure", "schedule", "exhibit", "table", "appendix", "linked_policy", "footer_notice", "banner_notice", "modal_notice", "faq", "unknown"]
        },
        "section_function": {
          "type": "string",
          "enum": [
            "definitions",
            "service_description",
            "ai_disclosure",
            "privacy_notice",
            "data_processing_terms",
            "subprocessor_terms",
            "acceptable_use_rules",
            "prohibited_use_rules",
            "security_terms",
            "breach_terms",
            "retention_deletion_terms",
            "rights_request_terms",
            "cross_border_transfer_terms",
            "liability_terms",
            "warranty_disclaimer",
            "sla_terms",
            "agentic_controls",
            "commercial_terms",
            "dispute_terms",
            "other",
            "unknown"
          ]
        },
        "control_topics_detected": { "$ref": "#/$defs/stringArray" },
        "feature_refs": { "$ref": "#/$defs/stringArray" },
        "data_flow_refs": { "$ref": "#/$defs/stringArray" },
        "source_record_ref": { "type": "string" },
        "source_locator": { "$ref": "#/$defs/sourceLocator" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "sourceLocator": {
      "type": "object",
      "required": ["locator_type", "locator_value"],
      "additionalProperties": false,
      "properties": {
        "locator_type": { "type": "string" },
        "locator_value": { "type": "string" }
      }
    },
    "documentRelationshipItem": {
      "type": "object",
      "required": [
        "relationship_id",
        "from_doc_id",
        "to_doc_id",
        "from_section_id",
        "to_section_id",
        "relationship_type",
        "relationship_signal",
        "section_refs",
        "source_record_ref",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "relationship_id": { "type": "string" },
        "from_doc_id": { "type": "string" },
        "to_doc_id": { "type": "string" },
        "from_section_id": { "type": "string" },
        "to_section_id": { "type": "string" },
        "relationship_type": {
          "type": "string",
          "enum": ["incorporates_by_reference", "supplements", "controls_on_conflict", "linked_from", "defines_terms_for", "activates_when", "supersedes_for_subject_matter", "unknown"]
        },
        "relationship_signal": { "$ref": "#/$defs/signal" },
        "section_refs": { "$ref": "#/$defs/stringArray" },
        "source_record_ref": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "documentControlSignalItem": {
      "type": "object",
      "required": [
        "control_signal_id",
        "doc_id",
        "section_id",
        "control_family",
        "coverage_signal",
        "feature_refs",
        "data_flow_refs",
        "basis_codes",
        "source_record_ref",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "control_signal_id": { "type": "string" },
        "doc_id": { "type": "string" },
        "section_id": { "type": "string" },
        "control_family": { "$ref": "#/$defs/controlFamily" },
        "coverage_signal": { "$ref": "#/$defs/signal" },
        "feature_refs": { "$ref": "#/$defs/stringArray" },
        "data_flow_refs": { "$ref": "#/$defs/stringArray" },
        "basis_codes": { "$ref": "#/$defs/stringArray" },
        "source_record_ref": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "controlFamily": {
      "type": "string",
      "enum": [
        "ai_disclosure",
        "hallucination_disclaimer",
        "hitl_mandate",
        "acceptable_use",
        "prohibited_use",
        "privacy_notice",
        "data_collection",
        "data_use",
        "data_sharing",
        "subprocessor_disclosure",
        "model_provider_disclosure",
        "training_or_finetuning",
        "retention",
        "deletion",
        "data_subject_rights",
        "consent_withdrawal",
        "grievance_channel",
        "security_safeguards",
        "breach_notice",
        "cross_border_transfer",
        "liability_cap",
        "warranty_disclaimer",
        "sla_performance",
        "agentic_controls",
        "unknown"
      ]
    },
    "documentMismatchSignalItem": {
      "type": "object",
      "required": [
        "mismatch_id",
        "mismatch_type",
        "left_ref_type",
        "left_ref",
        "right_ref_type",
        "right_ref",
        "control_family",
        "mismatch_signal",
        "basis_codes",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "mismatch_id": { "type": "string" },
        "mismatch_type": { "type": "string", "enum": ["feature_vs_document", "data_flow_vs_document", "document_vs_document", "claim_vs_absence", "stack_vs_reality", "unknown"] },
        "left_ref_type": { "type": "string" },
        "left_ref": { "type": "string" },
        "right_ref_type": { "type": "string" },
        "right_ref": { "type": "string" },
        "control_family": { "$ref": "#/$defs/controlFamily" },
        "mismatch_signal": { "$ref": "#/$defs/signal" },
        "basis_codes": { "$ref": "#/$defs/stringArray" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "legalStackSummarySignals": {
      "type": "object",
      "required": [
        "core_stack_status",
        "supplemental_artifacts_detected",
        "document_hierarchy_signal",
        "legal_stack_coverage_signal",
        "major_unknowns"
      ],
      "additionalProperties": false,
      "properties": {
        "core_stack_status": {
          "type": "object",
          "required": ["tos", "privacy_policy", "dpa", "aup", "sla"],
          "additionalProperties": false,
          "properties": {
            "tos": { "$ref": "#/$defs/signal" },
            "privacy_policy": { "$ref": "#/$defs/signal" },
            "dpa": { "$ref": "#/$defs/signal" },
            "aup": { "$ref": "#/$defs/signal" },
            "sla": { "$ref": "#/$defs/signal" }
          }
        },
        "supplemental_artifacts_detected": { "$ref": "#/$defs/stringArray" },
        "document_hierarchy_signal": { "$ref": "#/$defs/signal" },
        "legal_stack_coverage_signal": { "$ref": "#/$defs/signal" },
        "major_unknowns": { "$ref": "#/$defs/stringArray" }
      }
    },
    "legalStackLimitationItem": {
      "type": "object",
      "required": ["limitation_id", "scope", "doc_id", "section_id", "reason_code", "impact_code", "confidence"],
      "additionalProperties": false,
      "properties": {
        "limitation_id": { "type": "string" },
        "scope": { "type": "string" },
        "doc_id": { "type": "string" },
        "section_id": { "type": "string" },
        "reason_code": { "type": "string" },
        "impact_code": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "stage7NavigationIndex": {
      "type": "object",
      "required": [
        "feature_to_document_section_index",
        "control_family_index",
        "document_source_locator_index",
        "absence_unknown_index",
        "fallback_source_packet"
      ],
      "additionalProperties": false,
      "properties": {
        "feature_to_document_section_index": {
          "type": "array",
          "items": { "$ref": "#/$defs/featureDocumentSectionIndexItem" }
        },
        "control_family_index": {
          "type": "array",
          "items": { "$ref": "#/$defs/controlFamilyIndexItem" }
        },
        "document_source_locator_index": {
          "type": "array",
          "items": { "$ref": "#/$defs/documentSourceLocatorIndexItem" }
        },
        "absence_unknown_index": {
          "type": "array",
          "items": { "$ref": "#/$defs/absenceUnknownIndexItem" }
        },
        "fallback_source_packet": {
          "type": "array",
          "items": { "$ref": "#/$defs/fallbackSourcePacketItem" }
        }
      }
    },
    "featureDocumentSectionIndexItem": {
      "type": "object",
      "required": ["feature_id", "doc_ids", "section_ids", "control_families"],
      "additionalProperties": false,
      "properties": {
        "feature_id": { "type": "string" },
        "doc_ids": { "$ref": "#/$defs/stringArray" },
        "section_ids": { "$ref": "#/$defs/stringArray" },
        "control_families": {
          "type": "array",
          "items": { "$ref": "#/$defs/controlFamily" }
        }
      }
    },
    "controlFamilyIndexItem": {
      "type": "object",
      "required": ["control_family", "coverage_signal", "control_signal_ids", "doc_ids", "section_ids"],
      "additionalProperties": false,
      "properties": {
        "control_family": { "$ref": "#/$defs/controlFamily" },
        "coverage_signal": { "$ref": "#/$defs/signal" },
        "control_signal_ids": { "$ref": "#/$defs/stringArray" },
        "doc_ids": { "$ref": "#/$defs/stringArray" },
        "section_ids": { "$ref": "#/$defs/stringArray" }
      }
    },
    "documentSourceLocatorIndexItem": {
      "type": "object",
      "required": ["doc_id", "section_id", "source_record_ref", "source_url", "locator_type", "locator_value"],
      "additionalProperties": false,
      "properties": {
        "doc_id": { "type": "string" },
        "section_id": { "type": "string" },
        "source_record_ref": { "type": "string" },
        "source_url": { "type": "string" },
        "locator_type": { "type": "string" },
        "locator_value": { "type": "string" }
      }
    },
    "absenceUnknownIndexItem": {
      "type": "object",
      "required": ["signal_type", "object_ref", "search_scope", "absence_basis", "confidence"],
      "additionalProperties": false,
      "properties": {
        "signal_type": { "type": "string" },
        "object_ref": { "type": "string" },
        "search_scope": { "type": "string" },
        "absence_basis": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "fallbackSourcePacketItem": {
      "type": "object",
      "required": ["source_record_ref", "source_url", "source_type", "reason_for_fallback"],
      "additionalProperties": false,
      "properties": {
        "source_record_ref": { "type": "string" },
        "source_url": { "type": "string" },
        "source_type": { "type": "string" },
        "reason_for_fallback": { "type": "string" }
      }
    },
    "stage6Limitation": {
      "type": "object",
      "required": ["limitation_id", "scope", "reason_code", "impact_code", "confidence"],
      "additionalProperties": false,
      "properties": {
        "limitation_id": { "type": "string" },
        "scope": { "type": "string" },
        "reason_code": { "type": "string" },
        "impact_code": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    }
  }
}
