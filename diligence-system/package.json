{
  "name": "interface-diligence-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",

    "check": "npm run check:syntax && npm run check:imports",
    "check:syntax": "node --check server.js && node --check source-adapter.js && node --check phase-runner.js && node --check mechanical-output-validator.js && node --check reference-loader.js",
    "check:imports": "node -e \"import('./server.js').then(()=>console.log('IMPORT_OK server')).catch((err)=>{console.error(err);process.exit(1)})\"",

    "smoke": "node -e \"console.log('diligence-system package smoke ok')\"",
    "smoke:stack": "node -e \"import('./phase-runner.js').then(()=>console.log('PHASE_RUNNER_IMPORT_OK')).catch((err)=>{console.error(err);process.exit(1)})\""
  },
  "dependencies": {
    "express": "^4.19.2",
    "helmet": "^7.1.0"
  }
}
